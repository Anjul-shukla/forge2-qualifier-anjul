{
  "name": "forge2-qualifier-backend",
  "description": "Laravel API for tiny Kanban board",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^10.0",
    "doctrine/dbal": "^3.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
    "post-root-package-install": "@php artisan vendor:publish --provider=\"Laravel\\Telescope\\TelescopeServiceProvider\" --tag=config",
    "post-create-project-cmd": "@php artisan key:generate"
  }
}
